# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/letskonnect_production
DATABASE_REPLICA_URL=postgresql://postgres:password@replica:5432/letskonnect_production
DB_POOL=25

# Redis
REDIS_URL=redis://localhost:6379/0

# Rails
RAILS_ENV=production
SECRET_KEY_BASE=your_secret_key_base_here
RAILS_MAX_THREADS=5
PORT=3000
APP_HOST=https://letskonnect.in

# JWT
DEVISE_JWT_SECRET_KEY=your_jwt_secret_here

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# SMS OTP (Fast2SMS India)
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# AWS S3
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=letskonnect-assets

# Sidekiq
SIDEKIQ_USERNAME=admin
SIDEKIQ_PASSWORD=secure_password_here
