<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= @visitor.full_name %> — Expoza Pass</title>
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#0f0f1a;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px}
  .pass{background:linear-gradient(145deg,#1a1a2e,#16213e);border:1px solid rgba(108,99,255,0.3);border-radius:24px;width:100%;max-width:380px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,0.5)}
  .pass-header{background:linear-gradient(135deg,#6c63ff,#4a43d4);padding:24px 24px 20px;position:relative;overflow:hidden}
  .pass-header::before{content:'';position:absolute;top:-30px;right:-30px;width:120px;height:120px;background:rgba(255,255,255,0.06);border-radius:50%}
  .pass-header::after{content:'';position:absolute;bottom:-20px;left:-20px;width:80px;height:80px;background:rgba(255,255,255,0.04);border-radius:50%}
  .logo-row{display:flex;align-items:center;gap:8px;margin-bottom:16px;position:relative;z-index:1}
  .logo-dot{width:8px;height:8px;background:#fff;border-radius:50%;opacity:0.8}
  .logo-text{font-size:13px;font-weight:600;color:rgba(255,255,255,0.9);letter-spacing:0.05em}
  .visitor-name{font-size:22px;font-weight:700;color:#fff;line-height:1.2;position:relative;z-index:1;margin-bottom:4px}
  .visitor-role{font-size:13px;color:rgba(255,255,255,0.7);position:relative;z-index:1}
  .pass-body{padding:24px}
  .qr-section{background:#fff;border-radius:16px;padding:16px;text-align:center;margin-bottom:20px}
  .qr-section img{width:160px;height:160px}
  .visitor-id-row{text-align:center;margin-bottom:4px}
  .visitor-id-label{font-size:10px;text-transform:uppercase;letter-spacing:0.1em;color:rgba(255,255,255,0.4)}
  .visitor-id{font-size:20px;font-weight:700;color:#6c63ff;letter-spacing:0.05em}
  .divider{height:1px;background:rgba(255,255,255,0.08);margin:16px 0}
  .info-grid{display:grid;gap:10px}
  .info-row{display:flex;align-items:flex-start;gap:10px}
  .info-icon{font-size:16px;margin-top:1px;flex-shrink:0}
  .info-content{}
  .info-label{font-size:11px;color:rgba(255,255,255,0.4);margin-bottom:2px}
  .info-value{font-size:14px;font-weight:500;color:#fff}
  .event-strip{background:rgba(108,99,255,0.1);border:1px solid rgba(108,99,255,0.2);border-radius:12px;padding:14px;margin-top:16px}
  .event-name{font-size:14px;font-weight:600;color:#fff;margin-bottom:6px}
  .event-detail{font-size:12px;color:rgba(255,255,255,0.5);display:flex;gap:16px;flex-wrap:wrap}
  .footer-note{font-size:11px;color:rgba(255,255,255,0.3);text-align:center;margin-top:16px;padding-top:16px;border-top:1px solid rgba(255,255,255,0.06)}
</style>
</head>
<body>
<div class="pass">
  <div class="pass-header">
    <div class="logo-row"><div class="logo-dot"></div><span class="logo-text">Expoza</span></div>
    <div class="visitor-name"><%= @visitor.full_name %></div>
    <div class="visitor-role"><%= [@visitor.designation, @visitor.business_name].compact.join(" · ") %></div>
  </div>

  <div class="pass-body">
    <div class="qr-section">
      <% if @visitor.qr_image_url.present? %>
        <img src="<%= @visitor.qr_image_url %>" alt="Visitor QR">
      <% else %>
        <div style="width:160px;height:160px;background:#f5f5f5;display:flex;align-items:center;justify-content:center;border-radius:8px;margin:0 auto">
          <span style="font-size:12px;color:#999">Generating…</span>
        </div>
      <% end %>
    </div>

    <div class="visitor-id-row">
      <div class="visitor-id-label">Visitor ID</div>
      <div class="visitor-id"><%= @visitor.visitor_id_code %></div>
    </div>

    <div class="divider"></div>

    <div class="info-grid">
      <div class="info-row">
        <span class="info-icon">📱</span>
        <div class="info-content">
          <div class="info-label">Mobile</div>
          <div class="info-value"><%= @visitor.mobile_number %></div>
        </div>
      </div>
      <% if @visitor.profession.present? %>
      <div class="info-row">
        <span class="info-icon">💼</span>
        <div class="info-content">
          <div class="info-label">Profession</div>
          <div class="info-value"><%= @visitor.profession %></div>
        </div>
      </div>
      <% end %>
      <% if @visitor.business_category.present? %>
      <div class="info-row">
        <span class="info-icon">🏷️</span>
        <div class="info-content">
          <div class="info-label">Industry</div>
          <div class="info-value"><%= @visitor.business_category %></div>
        </div>
      </div>
      <% end %>
      <% if @visitor.location.present? %>
      <div class="info-row">
        <span class="info-icon">📍</span>
        <div class="info-content">
          <div class="info-label">Location</div>
          <div class="info-value"><%= @visitor.location %></div>
        </div>
      </div>
      <% end %>
    </div>

    <div class="event-strip">
      <div class="event-name">🎪 <%= @visitor.event.name %></div>
      <div class="event-detail">
        <span>📍 <%= @visitor.event.venue %></span>
        <span>📅 <%= @visitor.event.start_date.strftime("%b %d") %> – <%= @visitor.event.end_date.strftime("%b %d, %Y") %></span>
      </div>
    </div>

    <div class="footer-note">Scan this QR at exhibitor stalls to share your details instantly</div>
  </div>
</div>
</body>
</html>
