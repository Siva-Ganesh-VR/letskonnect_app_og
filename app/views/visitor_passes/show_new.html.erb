<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= @visitor.full_name %> — StallConnect Pass</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Inter',system-ui,sans-serif;background:linear-gradient(135deg,#f0fdfa 0%,#f8fafc 100%);min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;-webkit-font-smoothing:antialiased}
.pass{background:#ffffff;border-radius:24px;width:100%;max-width:380px;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,.14);border:1px solid #e2e8f0}
/* Header - teal gradient */
.pass-header{background:linear-gradient(135deg,#14b8a6,#0d9488);padding:24px 24px 20px;position:relative;overflow:hidden}
.pass-header::before{content:'';position:absolute;top:-30px;right:-30px;width:120px;height:120px;background:rgba(255,255,255,.08);border-radius:50%}
.pass-header::after{content:'';position:absolute;bottom:-20px;left:-20px;width:80px;height:80px;background:rgba(255,255,255,.05);border-radius:50%}
.logo-row{display:flex;align-items:center;gap:8px;margin-bottom:16px;position:relative;z-index:1}
.logo-dot{width:8px;height:8px;background:#fff;border-radius:50%;opacity:.85}
.logo-text{font-size:13px;font-weight:700;color:rgba(255,255,255,.9);letter-spacing:.06em}
.visitor-name{font-size:22px;font-weight:800;color:#fff;line-height:1.2;position:relative;z-index:1;margin-bottom:4px}
.visitor-role{font-size:13px;color:rgba(255,255,255,.75);position:relative;z-index:1;font-weight:500}
/* Body */
.pass-body{padding:24px}
.qr-section{background:#fff;border-radius:16px;padding:16px;text-align:center;margin-bottom:20px;border:1px solid #e2e8f0;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.qr-section img{width:160px;height:160px}
.visitor-id-row{text-align:center;margin-bottom:4px}
.visitor-id-label{font-size:10px;text-transform:uppercase;letter-spacing:.12em;color:#94a3b8;margin-bottom:4px;font-weight:600}
.visitor-id{font-size:22px;font-weight:800;color:#14b8a6;letter-spacing:.05em}
.divider{height:1px;background:#f1f5f9;margin:16px 0}
.info-grid{display:grid;gap:12px}
.info-row{display:flex;align-items:flex-start;gap:10px}
.info-icon{font-size:16px;margin-top:2px;flex-shrink:0}
.info-label{font-size:11px;color:#94a3b8;margin-bottom:2px;font-weight:600;text-transform:uppercase;letter-spacing:.04em}
.info-value{font-size:14px;font-weight:600;color:#0f172a}
/* Event strip - teal tint */
.event-strip{background:linear-gradient(135deg,#f0fdfa,#ccfbf1);border:1.5px solid rgba(20,184,166,.25);border-radius:14px;padding:14px;margin-top:16px}
.event-name{font-size:14px;font-weight:700;color:#0f172a;margin-bottom:6px}
.event-detail{font-size:12px;color:#64748b;display:flex;gap:14px;flex-wrap:wrap;font-weight:500}
.footer-note{font-size:11px;color:#94a3b8;text-align:center;margin-top:16px;padding-top:16px;border-top:1px solid #f1f5f9;font-weight:500}
</style>
</head>
<body>
<div class="pass">
  <div class="pass-header">
    <div class="logo-row"><div class="logo-dot"></div><span class="logo-text">StallConnect</span></div>
    <div class="visitor-name"><%= @visitor.full_name %></div>
    <div class="visitor-role"><%= [@visitor.designation, @visitor.business_name].compact.join(" · ") %></div>
  </div>
  <div class="pass-body">
    <div class="qr-section">
      <% if @visitor.qr_image_url.present? %>
        <img src="<%= @visitor.qr_image_url %>" alt="Visitor QR">
      <% else %>
        <div style="width:160px;height:160px;background:#f0fdfa;display:flex;align-items:center;justify-content:center;border-radius:10px;margin:0 auto;border:1px solid #e2e8f0">
          <span style="font-size:12px;color:#94a3b8;font-weight:500">Generating…</span>
        </div>
      <% end %>
    </div>
    <div class="visitor-id-row">
      <div class="visitor-id-label">Visitor ID</div>
      <div class="visitor-id"><%= @visitor.visitor_id_code %></div>
    </div>
    <div class="divider"></div>
    <div class="info-grid">
      <div class="info-row"><span class="info-icon">📱</span><div><div class="info-label">Mobile</div><div class="info-value"><%= @visitor.mobile_number %></div></div></div>
      <% if @visitor.profession.present? %>
      <div class="info-row"><span class="info-icon">💼</span><div><div class="info-label">Profession</div><div class="info-value"><%= @visitor.profession %></div></div></div>
      <% end %>
      <% if @visitor.business_category.present? %>
      <div class="info-row"><span class="info-icon">🏷️</span><div><div class="info-label">Industry</div><div class="info-value"><%= @visitor.business_category %></div></div></div>
      <% end %>
      <% if @visitor.location.present? %>
      <div class="info-row"><span class="info-icon">📍</span><div><div class="info-label">Location</div><div class="info-value"><%= @visitor.location %></div></div></div>
      <% end %>
    </div>
    <div class="event-strip">
      <div class="event-name">🎪 <%= @visitor.event.name %></div>
      <div class="event-detail">
        <span>📍 <%= @visitor.event.venue %></span>
        <span>📅 <%= @visitor.event.start_date.strftime("%b %d") %> – <%= @visitor.event.end_date.strftime("%b %d, %Y") %></span>
      </div>
    </div>
    <div class="footer-note">Scan this QR at exhibitor stalls to share your details instantly</div>
  </div>
</div>
</body>
</html>
